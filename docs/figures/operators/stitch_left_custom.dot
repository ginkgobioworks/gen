strict digraph "" {
	graph [fontnames=svg,
		rankdir=LR,
		nodesep=0
	];
	node [label="\N"];
	start	[fontsize=12,
		height=0.3,
		label=Start,
		margin=0,
		width=0.45];
	1 	[label=<<TABLE BORDER='0' CELLBORDER='1'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>ATGAGTAAAGGAGAAG</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:0-15</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	2	[label=<<TABLE BORDER='0' CELLBORDER='1' WIDTH='135'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>AACTTTTCACTGGAGT</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>2:0-15</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
 
	3 	[label=<<TABLE BORDER='0' CELLBORDER='1' WIDTH='140'><TR><TD WIDTH='0' BORDER='0'></TD><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>AACT</FONT></TD></TR><TR><TD WIDTH='0' BORDER='0'></TD><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:16-19</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];

	end	[fontsize=12,
		height=0.3,
		label=End,
		margin=0,
		width=0.45];

	start:e -> 1:seq:w;
	1:seq:e -> 2:seq:w [weight=10];
	1:seq:e -> 3:seq:w [style=dashed];
	2:seq:e -> end:w;

}

