strict digraph "" {
	graph [rankdir=LR,
		ranksep=0.5,
		splines=true
	];
	node [label="\N"];
	start	[label=start];
	1.0	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'>ATG</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:0-2</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	start:e -> 1.0:seq:w;
	1.3	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'>T</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:3</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.0:seq:e -> 1.3:seq:w	[style=dashed,
		weight=10];
	5.0	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'>A</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>5</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.0:seq:e -> 5.0:seq:w;
	1.4	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'>ATAC</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:4-7</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.3:seq:e -> 1.4:seq:w	[style=dashed,
		weight=10];
	1.8	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'>AT</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:8-9</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.4:seq:e -> 1.8:seq:w	[style=dashed,
		weight=10];
	2.0	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'>TG</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>2:0-1</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.4:seq:e -> 2.0:seq:w;
	1.10	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'>CACGGC</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:10-15</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.8:seq:e -> 1.10:seq:w	[style=dashed,
		weight=10];
	end	[label=end];
	1.10:seq:e -> end:w;
	5.0:seq:e -> 1.4:seq:w;
	2.0:seq:e -> 1.10:seq:w;
}
