strict digraph "" {
	graph [fontnames=svg,
		rankdir=LR,
		nodesep=0
	];
	node [label="\N"];
	start	[fontsize=12,
		height=0.3,
		label=Start,
		margin=0,
		width=0.45];



    1	[label=<<TABLE BORDER='0' CELLSPACING='0' WIDTH='115'><TR><TD ALIGN='CENTER' BORDER='1' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>ATGAGTAAAGGAGAAG</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER' ><FONT POINT-SIZE='10'>1:0-15</FONT></TD></TR></TABLE>>,
        shape=none];

    2	[label=<<TABLE BORDER='0'><TR><TD BORDER='1' ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>AACTTTTCACTGGAGT</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>2:2-15</FONT></TD></TR></TABLE>>,
        shape=none];

    3 	[label=<<TABLE BORDER='0' CELLSPACING='0'><TR><TD ALIGN='CENTER' BORDER='1' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>AA</FONT></TD><TD BORDER='0' WIDTH='90'></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:16-17</FONT></TD><TD BORDER='0'></TD></TR></TABLE>>,
        shape=none];

	4   [label=<<TABLE BORDER='0' CELLSPACING='0'><TR><TD BORDER='0' WIDTH='100'></TD><TD ALIGN='CENTER' BORDER='1' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>AG</FONT></TD></TR><TR><TD BORDER='0'></TD><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>2:0-1</FONT></TD></TR></TABLE>>,
            shape=none];

	end	[fontsize=12,
		height=0.3,
		label=End,
		margin=0,
		width=0.45];

	start:e -> 1:seq:w;
	1:seq:e -> 2:seq:w [weight=10];
	1:seq:e -> 3:seq:w [style=dashed];
    4:seq:e -> 2:seq:w [style=dashed];
	2:seq:e -> end:w;

}

