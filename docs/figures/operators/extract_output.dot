strict digraph "" {
	graph [fontnames=svg,
		rankdir=LR,
		ranksep=0.5,
		splines=true
	];
	node [label="\N"];
	start	[label=start];
	1.5	[label=<<TABLE BORDER='0' CELLBORDER='1'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>TAA</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:5-7</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	start:e -> 1.5:seq:w;
	1.8	[label=<<TABLE BORDER='0' CELLBORDER='1'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>AG</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:8-9</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.5:seq:e -> 1.8:seq:w	[style=dashed,
		weight=10];
	3.0	[label=<<TABLE BORDER='0' CELLBORDER='1'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>TG</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>3:0-1</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.5:seq:e -> 3.0:seq:w;
	1.10	[label=<<TABLE BORDER='0' CELLBORDER='1'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>GAG</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:10-12</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.8:seq:e -> 1.10:seq:w	[style=dashed,
		weight=10];
	end	[label=end];
	1.10:seq:e -> end:w;
	3.0:seq:e -> 1.10:seq:w;
}
