strict digraph "" {
	graph [fontnames=svg,
		rankdir=LR,
		ranksep=0.5,
		splines=true
	];
	node [label="\N"];
	start	[fontsize=12,
		height=0.3,
		label=Start,
		margin=0,
		width=0.45];
	1.0	[label=<<TABLE BORDER='0' CELLBORDER='1'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>ATGTATAC</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:0-7</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	start:e -> 1.0:seq:w;
	1.8	[label=<<TABLE BORDER='0' CELLBORDER='1'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>AT</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:8-9</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.0:seq:e -> 1.8:seq:w	[style=dashed,
		weight=10];
	2.0	[label=<<TABLE BORDER='0' CELLBORDER='1'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'><B>TG</B></FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>2:0-1</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.0:seq:e -> 2.0:seq:w;
	1.10	[label=<<TABLE BORDER='0' CELLBORDER='1'><TR><TD ALIGN='CENTER' PORT='seq'><FONT POINT-SIZE='12' FACE='Monospace'>CACGGC</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1:10-15</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.8:seq:e -> 1.10:seq:w	[style=dashed,
		weight=10];
	end	[fontsize=12,
		height=0.3,
		label=End,
		margin=0,
		width=0.45];
	1.10:seq:e -> end:w;
	2.0:seq:e -> 1.10:seq:w;
}
