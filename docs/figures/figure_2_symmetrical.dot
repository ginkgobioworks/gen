strict digraph "" {
	graph [rankdir=LR,
		ranksep=0.5,
		splines=true
	];
	node [label="\N"];
	start	[label=start];
	1.0	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'><B>ATGTATAC</B></FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1.0 - 7</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	start:e -> 1.0:seq:w;
	1.8	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'>AT</FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1.8</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.0:seq:e -> 1.8:seq:w	[style=dashed];
	2.0	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'><B>TG</B></FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>2.0</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.0:seq:e -> 2.0:seq:w;
	1.10	[label=<<TABLE BORDER='0' CELLBORDER='1' CELLSPACING='0'><TR><TD ALIGN='CENTER' PORT='seq'><FONT FACE='Courier'><B>CACGGC</B></FONT></TD></TR><TR><TD BORDER='0' ALIGN='CENTER'><FONT POINT-SIZE='10'>1.10 - 15</FONT></TD></TR></TABLE>>,
		margin=0,
		shape=none];
	1.8:seq:e -> 1.10:seq:w	[style=dashed];
	end	[label=end];
	1.10:seq:e -> end:w;
	2.0:seq:e -> 1.10:seq:w;
}
